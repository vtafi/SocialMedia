# ==============================
# DEPENDENCIES
# ==============================
# Không copy node_modules vào image (sẽ được cài lại trong Docker)
node_modules
npm-debug.log*
yarn-error.log*

# ==============================
# BUILD OUTPUT
# ==============================
# dist/ sẽ được tạo bởi lệnh build trong stage builder
dist

# ==============================
# ENVIRONMENT FILES - BẢO MẬT
# ==============================
# Chặn TOÀN BỘ file .env -> biến môi trường sẽ được inject lúc runtime qua env_file
.env
.env.*
!.env.example       # Chỉ cho phép file example (không có secret)

# ==============================
# GIT
# ==============================
.git
.gitignore
.gitattributes

# ==============================
# IDE / EDITOR
# ==============================
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# ==============================
# LOGS
# ==============================
logs
*.log

# ==============================
# TESTING
# ==============================
coverage
.nyc_output
*.test.ts
*.spec.ts
__tests__

# ==============================
# UPLOADS & TEMP
# ==============================
# Uploads được mount qua volume, không cần bake vào image
uploads/*
!uploads/.gitkeep
tmp
temp

# ==============================
# DOCS (không cần trong runtime, trừ API_DOCUMENT.yaml)
# ==============================
README.md
CHANGELOG.md
LICENSE

# ==============================
# CI/CD
# ==============================
.github
.gitlab-ci.yml
.travis.yml

# ==============================
# LINTING & FORMATTING
# ==============================
.eslintrc*
eslint.config.mts
.prettierrc*
.prettierignore
.editorconfig

# ==============================
# DOCKER FILES (không cần bên trong image)
# ==============================
Dockerfile
docker-compose.yml
.dockerignore
